# Runtime files
ASTEROID_DATABASE_PATH=data/asteroids.db
ASTEROID_VIEWER_EXPORT_PATH=data/latest_intercepts.json

# JPL CAD/SBDB ingestion window
JPL_DATE_MIN=now
JPL_DATE_MAX=+60
JPL_DISTANCE_MAX_AU=0.05
JPL_RESULT_LIMIT=2000

# Lambert search grid
INTERCEPT_TOF_MIN_DAYS=30
INTERCEPT_TOF_MAX_DAYS=180
INTERCEPT_TOF_STEP_DAYS=10
INTERCEPT_ARRIVAL_OFFSETS_HOURS=-12,-6,0,6,12
LEO_ALTITUDE_KM=500

# Earth state model: analytic is deterministic; skyfield uses a JPL DE kernel
EPHEMERIS_MODE=analytic
JPL_EPHEMERIS_PATH=

# Local dashboard
FLASK_HOST=127.0.0.1
FLASK_PORT=5000
FLASK_DEBUG=0
SECRET_KEY=replace-with-a-random-local-secret
